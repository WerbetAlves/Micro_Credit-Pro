# OPENAI_API_KEY: chave usada apenas no backend para o chat, insights e contratos.
OPENAI_API_KEY="MY_OPENAI_API_KEY"

# OPENAI_MODEL: opcional. Se nao informar, o backend usa gpt-4.1-mini.
OPENAI_MODEL="gpt-4.1-mini"

# GEMINI_API_KEY: fallback usado quando a OpenAI ficar sem cota ou billing.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: opcional. Se nao informar, o backend usa gemini-2.5-flash.
GEMINI_MODEL="gemini-2.5-flash"

# APP_URL: URL da aplicacao quando publicada.
APP_URL="MY_APP_URL"

